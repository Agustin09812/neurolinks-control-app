{
  "name": "neurolinks-crm",
  "version": "1.1.2",
  "description": "CRM Gestión Neurolinks",
  "author": "Neurolinks",
  "main": "src/main/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "dotenv": "^17.3.1"
  },
  "build": {
    "appId": "com.neurolinks.control",
    "productName": "Neurolinks Control",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "executableName": "Neurolinks Control",
    "win": {
      "icon": "assets/icons/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}